{
  "name": "slowpoker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "eslint . --cache --cache-location .cache/eslint && prettier --check .",
    "fix": "eslint . --cache --fix --cache-location .cache/eslint && prettier --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.4",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.6",
    "next": "16.1.6",
    "poker-evaluator": "^2.1.0",
    "pokersolver": "^2.1.4",
    "postgres": "^3.4.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^20.19.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --fix --cache-location .cache/eslint"
    ],
    "*": [
      "prettier --write --ignore-unknown"
    ]
  }
}
